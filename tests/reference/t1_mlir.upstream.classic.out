module {
  func.func @matrix_add(%4: memref<10x20xf32>, %5: memref<10x20xf32>) -> memref<10x20xf32> {
    %0 = memref.alloc() : memref<10x20xf32>
    affine.for %6 = 0 to 10 {
      affine.for %7 = 0 to 20 {
        %1 = memref.load %4[%6, %7] : memref<10x20xf32>
        %2 = memref.load %5[%6, %7] : memref<10x20xf32>
        %3 = arith.addf %1, %2 : f32
        memref.store %3, %0[%6, %7] : memref<10x20xf32>
      }
    }
    return %0 : memref<10x20xf32>
  }
}
