module {
^bb0:
    tt.func(%arg0: !tt.ptr<f32>, %arg1: !tt.ptr<f32>, %arg2: !tt.ptr<f32>, %arg3: i32) {
    ^bb0:
        %c16_i32 = arith.constant 16 : i32
