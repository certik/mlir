        %10 = tt.load(%9: tensor<16x!tt.ptr<f32>>) -> tensor<16x!tt.ptr<f32>>
        %11 = arith.addf(%7: tensor<16x!tt.ptr<f32>>, %10: tensor<16x!tt.ptr<f32>>) -> tensor<16xf32>
