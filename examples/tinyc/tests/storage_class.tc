extern int printf(const char *fmt, ...);
// Storage-class qualifiers: parser-only acceptance.

static int counter = 0;
static const int kSeed = 10;
const static int kSeed2 = 20;

static int incr(void) {
    counter = counter + 1;
    return counter;
}

static inline int squared(int n) {
    return n * n;
}

inline static int cubed(int n);  // forward decl with both, swapped

int main() {
    printf("%lld\n", (long long)(incr()));
    printf("%lld\n", (long long)(incr()));
    printf("%lld\n", (long long)(incr()));
    printf("%lld\n", (long long)(squared(5)));
    printf("%lld\n", (long long)(cubed(3)));
    printf("%lld\n", (long long)(kSeed + kSeed2));
    return 0;
}

inline static int cubed(int n) {
    return n * n * n;
}
