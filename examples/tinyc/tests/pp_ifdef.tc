extern int printf(const char *fmt, ...);
// Conditional compilation: #ifdef, #ifndef, #else, #endif, #undef,
// #if defined(X), #elif.

#define FEATURE_A
#define VERSION 2

int main() {
#ifdef FEATURE_A
    printf("%lld\n", (long long)(1));            // 1
#else
    printf("%lld\n", (long long)(99));
#endif

#ifndef FEATURE_A
    printf("%lld\n", (long long)(99));
#else
    printf("%lld\n", (long long)(2));            // 2
#endif

#undef FEATURE_A

#ifdef FEATURE_A
    printf("%lld\n", (long long)(99));
#else
    printf("%lld\n", (long long)(3));            // 3
#endif

#if defined(VERSION) && VERSION == 2
    printf("%lld\n", (long long)(4));            // 4
#elif defined(VERSION)
    printf("%lld\n", (long long)(99));
#else
    printf("%lld\n", (long long)(99));
#endif

#if !defined(FEATURE_A)
    printf("%lld\n", (long long)(5));            // 5
#endif

#if VERSION > 5
    printf("%lld\n", (long long)(99));
#elif VERSION > 1
    printf("%lld\n", (long long)(6));            // 6
#else
    printf("%lld\n", (long long)(99));
#endif
    return 0;
}
