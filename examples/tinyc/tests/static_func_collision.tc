extern int printf(const char *fmt, ...);
// Regression test driver. Compiled separately from the helper TUs and
// linked against them — exercises wasm-link symbol resolution for
// `static` symbols defined in multiple TUs with the same C name.

int call_a(int v);
int call_b(int v);

int main() {
    printf("%lld\n", (long long)(call_a(1)));  // 1 + 100 = 101
    printf("%lld\n", (long long)(call_b(1)));  // 1 + 200 = 201
    printf("%lld\n", (long long)(call_a(5)));  // 105
    printf("%lld\n", (long long)(call_b(5)));  // 205
    return 0;
}
