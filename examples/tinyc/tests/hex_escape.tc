extern int printf(const char *fmt, ...);
// Regression test: `\xHH...` (hex) escape in string and char literals.
// Previously tinyc's lexer rejected '\\x' with "unknown escape '\\x'"
// in both contexts.
//
// Triggered by mlir_wasm_to_wat.c:447, which embeds a magic byte
// sequence "\x00asm\x01\x00\x00\x00" to compare with the WASM module
// header. Self-hosting tinyc through tinyc.wasm needs to lex it.
//
// `\xHH...` consumes as many hex digits as appear; the resulting byte
// is the low 8 bits of the parsed value (matches C's "low-bits of the
// integer constant" rule for character constants — exact value
// preserved when at most two hex digits are used, which covers every
// occurrence in this codebase).

int main(void) {
    // Hex bytes in a string literal — including embedded NUL.
    // Use adjacent string literals to terminate \x escapes that would
    // otherwise greedily consume following hex digits (e.g. "\x00asm"
    // would parse as "\x00a" + "sm").
    char *m = "\x00" "asm" "\x01\x00\x00\x00";
    printf("%lld\n", (long long)((int)m[0]));  // 0
    printf("%lld\n", (long long)((int)m[1]));  // 'a' = 97
    printf("%lld\n", (long long)((int)m[2]));  // 's' = 115
    printf("%lld\n", (long long)((int)m[3]));  // 'm' = 109
    printf("%lld\n", (long long)((int)m[4]));  // 1
    printf("%lld\n", (long long)((int)m[5]));  // 0
    printf("%lld\n", (long long)((int)m[6]));  // 0
    printf("%lld\n", (long long)((int)m[7]));  // 0

    // Upper- and lower-case hex digits in char literals.
    printf("%lld\n", (long long)((int)'\x41'));  // 'A' = 65
    printf("%lld\n", (long long)((int)'\x7f'));  // 127

    // Greedy multi-digit hex consumption (only stops on non-hex byte).
    printf("%lld\n", (long long)((int)'\x0a'));  // 10 (LF)

    return 0;
}
