extern int printf(const char *fmt, ...);
// `void*` as a generic pointer type. Round-trip a pointer through a
// `void*` slot, dereference after casting back, pass `void*` through a
// callback-style function, and use `void*` as a struct field.

struct Box {
    int value;
    void* ctx;
};

int read_through(void* p) {
    int* ip = (int*)p;
    return *ip;
}

void* identity(void* p) {
    return p;
}

int main() {
    int x = 17;
    void* vp = &x;       // typed pointer -> void*

    int* ip = (int*)vp;  // void* -> typed pointer
    printf("%lld\n", (long long)(*ip));          // 17

    printf("%lld\n", (long long)(read_through(&x)));  // 17

    // void* round-trip through a function.
    void* vq = identity(vp);
    int* iq = (int*)vq;
    *iq = 99;
    printf("%lld\n", (long long)(x));                 // 99

    // void* as a struct field.
    struct Box b;
    b.value = 5;
    b.ctx = &x;
    int* ic = (int*)b.ctx;
    printf("%lld\n", (long long)(*ic));               // 99
    printf("%lld\n", (long long)(b.value));           // 5

    // void** works too.
    void* arr_ctx = vp;
    void* alias = arr_ctx;
    int* ia = (int*)alias;
    printf("%lld\n", (long long)(*ia));               // 99

    return 0;
}
