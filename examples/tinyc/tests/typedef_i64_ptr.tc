extern int printf(const char *fmt, ...);
// `Td *` where Td is a typedef for `long`/i64 must yield a 64-bit pointer.

typedef long Long;

void fill(Long *buf, int n) {
    int i;
    for (i = 0; i < n; i = i + 1) {
        buf[i] = (long)(100 + i);
    }
}

int main() {
    Long *p;
    p = (Long *)malloc(sizeof(long) * 4);
    fill(p, 4);
    printf("%lld\n", (long long)(p[0]));
    printf("%lld\n", (long long)(p[1]));
    printf("%lld\n", (long long)(p[2]));
    printf("%lld\n", (long long)(p[3]));
    free(p);
    return 0;
}
