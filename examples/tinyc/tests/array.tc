extern int printf(const char *fmt, ...);
int main() {
    int a[5];
    int i = 0;
    for (i = 0; i < 5; i = i + 1) {
        a[i] = i * i;
    }
    int sum = 0;
    for (i = 0; i < 5; i = i + 1) {
        sum = sum + a[i];
    }
    printf("%lld\n", (long long)(sum));          // 0+1+4+9+16 = 30
    printf("%lld\n", (long long)(a[3]));         // 9
    return 0;
}
