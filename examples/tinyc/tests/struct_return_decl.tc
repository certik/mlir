extern int printf(const char *fmt, ...);
struct Pos { int chunk_id; int ofs; };

struct Pos make(int a, int b) {
    struct Pos r = {.chunk_id = a, .ofs = b};
    return r;
}

int main() {
    struct Pos p = make(7, 42);
    printf("%lld\n", (long long)((int64_t)p.chunk_id));
    printf("%lld\n", (long long)((int64_t)p.ofs));
    struct Pos q = make(100, 200);
    printf("%lld\n", (long long)((int64_t)q.chunk_id));
    printf("%lld\n", (long long)((int64_t)q.ofs));
    return 0;
}
