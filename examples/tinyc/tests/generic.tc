extern int printf(const char *fmt, ...);
// _Generic: static type-based selection. Verify each branch is picked
// correctly. The controlling expression is NOT evaluated, so a side
// effect inside it must not appear in the output.

typedef struct Box {
    int w;
    int h;
} Box;

int side_effect(int x) {
    printf("%lld\n", (long long)(999));  // must NOT be printed if controlling expr is not evaluated
    return x;
}

int main() {
    int  i = 7;
    long l = 42;
    char *s = "hi";
    Box  b;
    b.w = 1; b.h = 2;
    Box *bp = &b;

    // Branch on int -> should print 1
    printf("%lld\n", (long long)(_Generic((i), int: 1, long: 2, char*: 3, struct Box: 4, struct Box*: 5, default: 9)));
    // Branch on long -> 2
    printf("%lld\n", (long long)(_Generic((l), int: 1, long: 2, char*: 3, struct Box: 4, struct Box*: 5, default: 9)));
    // Branch on char* -> 3
    printf("%lld\n", (long long)(_Generic((s), int: 1, long: 2, char*: 3, struct Box: 4, struct Box*: 5, default: 9)));
    // Branch on struct Box -> 4
    printf("%lld\n", (long long)(_Generic((b), int: 1, long: 2, char*: 3, struct Box: 4, struct Box*: 5, default: 9)));
    // Branch on struct Box* -> 5
    printf("%lld\n", (long long)(_Generic((bp), int: 1, long: 2, char*: 3, struct Box: 4, struct Box*: 5, default: 9)));
    // Default branch (float not in list) -> 9
    printf("%lld\n", (long long)(_Generic((1.5f), int: 1, long: 2, char*: 3, default: 9)));
    // Controlling expr must not be evaluated.
    printf("%lld\n", (long long)(_Generic((side_effect(0)), int: 100, default: 9)));
    // Narrow-int discrimination via int_bits.
    {
        int8_t  i8  = 1;
        int16_t i16 = 2;
        int32_t i32 = 3;
        printf("%lld\n", (long long)(_Generic((i8),  int8_t: 8,  int16_t: 16, int32_t: 32, default: 0)));
        printf("%lld\n", (long long)(_Generic((i16), int8_t: 8,  int16_t: 16, int32_t: 32, default: 0)));
        printf("%lld\n", (long long)(_Generic((i32), int8_t: 8,  int16_t: 16, int32_t: 32, default: 0)));
    }
    return 0;
}
