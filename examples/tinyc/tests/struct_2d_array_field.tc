extern int printf(const char *fmt, ...);
// Struct with a 2-D array-of-float field. Exercises s.m[i][j] reads/writes.

struct Mat {
    float m[2][3];
};

int main() {
    struct Mat M;
    int i = 0;
    int j = 0;
    for (i = 0; i < 2; i = i + 1) {
        for (j = 0; j < 3; j = j + 1) {
            M.m[i][j] = i * 10 + j;
        }
    }
    printf("%lld\n", (long long)(M.m[0][0]));    // 0
    printf("%lld\n", (long long)(M.m[0][2]));    // 2
    printf("%lld\n", (long long)(M.m[1][0]));    // 10
    printf("%lld\n", (long long)(M.m[1][2]));    // 12

    M.m[1][1] = M.m[0][2] + M.m[1][0] + 0.5;
    printf("%g\n", (double)(M.m[1][1]));    // 12.5
    return 0;
}
