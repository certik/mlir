extern int printf(const char *fmt, ...);
size_t triangle(size_t n) {
    size_t s;
    size_t i;
    s = 0LL;
    i = 0LL;
    while (i < n) {
        i = i + 1LL;
        s = s + i;
    }
    return s;
}

int main() {
    printf("%lld\n", (long long)(triangle(10LL)));
    printf("%lld\n", (long long)(triangle(100LL)));
    printf("%lld\n", (long long)(triangle(0LL)));
    return 0;
}
