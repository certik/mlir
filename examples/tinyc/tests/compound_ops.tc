extern int printf(const char *fmt, ...);
int main() {
    int x = 10;
    x += 5;
    printf("%lld\n", (long long)(x));
    x -= 2;
    printf("%lld\n", (long long)(x));
    x *= 3;
    printf("%lld\n", (long long)(x));
    x /= 4;
    printf("%lld\n", (long long)(x));
    x %= 5;
    printf("%lld\n", (long long)(x));
    x = 0;
    int i;
    for (i = 0; i < 5; i = i + 1) {
        x += i;
    }
    printf("%lld\n", (long long)(x));
    int j = 0;
    j++;
    j++;
    printf("%lld\n", (long long)(j));
    j--;
    printf("%lld\n", (long long)(j));
    return 0;
}
