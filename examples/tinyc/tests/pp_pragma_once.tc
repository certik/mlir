extern int printf(const char *fmt, ...);
// pragma once: pp_a.h is included transitively via pp_b.h AND directly.
// Without pragma once we'd get a duplicate-symbol error from emitting
// once_value twice.
#include "pp_a.h"
#include "pp_b.h"

int main() {
    printf("%lld\n", (long long)(once_value())); // 7
    printf("%lld\n", (long long)(b_call()));     // 7
    return 0;
}
