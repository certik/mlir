extern int printf(const char *fmt, ...);
// Basic `double` (TY_F64) support: literal, arithmetic, comparison,
// casts to/from int and float, and printing.
int main() {
    double a;
    double b;
    a = 1.5;
    b = 2.25;
    double s;
    s = a + b;
    printf("%g\n", (double)(s));            // 3.75

    double p;
    p = a * b;
    printf("%g\n", (double)(p));            // 3.375

    double n;
    n = -a;
    printf("%g\n", (double)(n));            // -1.5

    int i;
    i = (int)b;
    printf("%lld\n", (long long)(i));            // 2

    double d;
    d = (double)7;
    printf("%g\n", (double)(d));            // 7

    float f;
    f = 3.5f;
    double w;
    w = (double)f;
    printf("%g\n", (double)(w));            // 3.5

    if (a < b) printf("%lld\n", (long long)(1)); else printf("%lld\n", (long long)(0));  // 1
    return 0;
}
