extern int printf(const char *fmt, ...);
// Regression: tinyc must concatenate adjacent string literals like C.
// Used heavily in mlir/parser.c (multi-line MLIR text literals).
int main() {
    char *s;
    s = "hello"
        " "
        "world";
    printf("%lld\n", (long long)(s[0]));
    printf("%lld\n", (long long)(s[5]));
    printf("%lld\n", (long long)(s[6]));
    printf("%lld\n", (long long)(s[10]));
    return 0;
}
