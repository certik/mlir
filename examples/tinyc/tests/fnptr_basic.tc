extern int printf(const char *fmt, ...);
int add(int a, int b) {
    return a + b;
}

int sub(int a, int b) {
    return a - b;
}

int main() {
    int (*op)(int, int);
    op = &add;
    printf("%lld\n", (long long)(op(3, 4)));
    op = sub;
    printf("%lld\n", (long long)(op(10, 3)));
    return 0;
}
