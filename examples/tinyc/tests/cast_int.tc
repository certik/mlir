extern int printf(const char *fmt, ...);
// `(int)x` and `(long)x` are accepted as integer-to-integer casts and
// behave like the standard C narrowing/widening conversions.
int main() {
    long a;
    int b;
    a = 100LL;
    b = (int)a;
    printf("%lld\n", (long long)(b));          // 100

    int c;
    c = 7;
    long d;
    d = (long)c;
    printf("%lld\n", (long long)(d * 1000LL)); // 7000

    long e;
    e = 8589934591LL;
    int f;
    f = (int)e;        // truncated to 32-bit (low 32 bits = -1)
    printf("%lld\n", (long long)(f));          // -1
    return 0;
}
