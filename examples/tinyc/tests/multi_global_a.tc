extern int printf(const char *fmt, ...);
// multi_global: a.tc forward-declares the global `counter` (extern),
// b.tc provides the definition. The parser merges tentative+def into
// the initialized definition.

extern int counter;

int main() {
    printf("%lld\n", (long long)(counter));    // 10
    counter = counter + 5;
    printf("%lld\n", (long long)(counter));    // 15
    return 0;
}
