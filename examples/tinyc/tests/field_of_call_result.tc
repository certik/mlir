extern int printf(const char *fmt, ...);
struct Pair { int a; int b; };

struct Pair make(int a, int b) {
    struct Pair p; p.a = a; p.b = b;
    return p;
}

int main() {
    printf("%lld\n", (long long)(make(7, 11).a));
    printf("%lld\n", (long long)(make(7, 11).b));
    printf("%lld\n", (long long)(make(100, 200).a + make(3, 4).b));
    return 0;
}
