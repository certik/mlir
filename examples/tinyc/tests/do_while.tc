// do-while: body always executes once before condition is tested.
int main() {
    int i;
    int s;
    i = 0;
    s = 0;
    do {
        s = s + i;
        i = i + 1;
    } while (i < 5);
    print(s);  // 0+1+2+3+4 = 10

    // body runs at least once even when cond is false initially.
    i = 100;
    do {
        i = i + 1;
    } while (i < 0);
    print(i);  // 101

    // break / continue inside do-while.
    i = 0;
    s = 0;
    do {
        i = i + 1;
        if (i == 3) { continue; }
        if (i == 7) { break; }
        s = s + i;
    } while (i < 100);
    print(i);  // 7
    print(s);  // 1+2+4+5+6 = 18
    return 0;
}
