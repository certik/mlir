extern int printf(const char *fmt, ...);
// Verifies `S s = {0}` zeroes all bytes of i64/f64/ptr-to-ptr/fnptr fields
// (regression: tinyc was emitting i32 stores for these, leaving high 32 bits
// uninitialized).

typedef int (*FnPtr)(int);

typedef struct S {
    long *pp;       // ptr (was zeroed with i32 0 only)
    long n;         // i64 (was zeroed with i32 0 only)
    double d;       // f64
    FnPtr fp;       // ptr
    int **ppi;      // TY_PTR_PTR
} S;

int main(void) {
    // Stack-allocate uninitialized garbage first to dirty memory.
    int buf[64];
    int i;
    for (i = 0; i < 64; i = i + 1) buf[i] = -1;
    // The compiler may reuse this stack region for `s` below.
    S s = {0};
    // High bits must be zero.
    if (s.n != 0) { printf("%lld\n", (long long)(1)); return 1; }
    if (s.pp != 0) { printf("%lld\n", (long long)(2)); return 2; }
    if (s.d != 0.0) { printf("%lld\n", (long long)(3)); return 3; }
    if (s.fp != 0) { printf("%lld\n", (long long)(4)); return 4; }
    if (s.ppi != 0) { printf("%lld\n", (long long)(5)); return 5; }
    printf("%lld\n", (long long)(0));
    return 0;
}
