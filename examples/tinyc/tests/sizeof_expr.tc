extern int printf(const char *fmt, ...);
struct Point {
    int x;
    int y;
};

int main() {
    int a;
    long long b;
    char *s;
    struct Point p;
    a = 0;
    b = 0LL;
    s = "hi";
    p.x = 0;
    p.y = 0;
    printf("%lld\n", (long long)(sizeof(int)));
    printf("%lld\n", (long long)(sizeof(a)));
    printf("%lld\n", (long long)(sizeof(b)));
    printf("%lld\n", (long long)(sizeof(s)));
    printf("%lld\n", (long long)(sizeof(p)));
    printf("%lld\n", (long long)(sizeof(p.x)));
    printf("%lld\n", (long long)(sizeof(a + 1)));
    printf("%lld\n", (long long)(sizeof(a + b)));
    return 0;
}
