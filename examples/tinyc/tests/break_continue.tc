extern int printf(const char *fmt, ...);
int main() {
    int s = 0;
    int i = 0;
    while (i < 10) {
        i = i + 1;
        if (i == 4) {
            continue;
        }
        if (i == 7) {
            break;
        }
        s = s + i;
    }
    printf("%lld\n", (long long)(s));    // 1+2+3+5+6 = 17
    printf("%lld\n", (long long)(i));    // 7
    return 0;
}
