extern int printf(const char *fmt, ...);
// Tests struct-pointer return types and mid-chain pointer-field walks.
//
//   - make_node returns struct Node*; lets us factor out the malloc.
//   - find_tail walks `head->next->next->...` to find the end.
//   - mid-chain field access: head->next->value reaches inside two pointers
//     within a single lvalue chain.

struct Node {
    int value;
    struct Node* next;
};

struct Node* make_node(int v) {
    struct Node* n;
    n = (struct Node*)malloc(sizeof(struct Node));
    n->value = v;
    n->next = null;
    return n;
}

struct Node* find_tail(struct Node* head) {
    while (head->next != null) {
        head = head->next;
    }
    return head;
}

int sum_three(struct Node* head) {
    // Mid-chain pointer-field walks in a single lvalue.
    return head->value + head->next->value + head->next->next->value;
}

int main() {
    struct Node* a;
    struct Node* b;
    struct Node* c;
    a = make_node(10);
    b = make_node(20);
    c = make_node(30);
    a->next = b;
    b->next = c;
    printf("%lld\n", (long long)(sum_three(a)));            // 60

    // Mid-chain assignment through two pointer fields.
    a->next->next->value = 99;
    printf("%lld\n", (long long)(a->next->next->value));    // 99
    printf("%lld\n", (long long)(c->value));                // 99 (same node)

    struct Node* tail;
    tail = find_tail(a);
    printf("%lld\n", (long long)(tail->value));             // 99

    free(a); free(b); free(c);
    return 0;
}
