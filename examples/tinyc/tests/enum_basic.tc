extern int printf(const char *fmt, ...);
// Anonymous enum: implicit 0..N counting.
enum { RED, GREEN, BLUE };

// Named enum, mixing explicit and implicit values:
//   A=1, B=2, C=10, D=11.
enum Letters { A = 1, B, C = 10, D };

// Reference a previously-declared enumerator in an initializer.
enum Aliases { ALPHA = A, BETA, GAMMA = C };

int classify(int color) {
    switch (color) {
        case RED:   return 100;
        case GREEN: return 200;
        case BLUE:  return 300;
        default:    return -1;
    }
}

int main() {
    printf("%lld\n", (long long)(RED));          // 0
    printf("%lld\n", (long long)(GREEN));        // 1
    printf("%lld\n", (long long)(BLUE));         // 2
    printf("%lld\n", (long long)(A));            // 1
    printf("%lld\n", (long long)(B));            // 2
    printf("%lld\n", (long long)(C));            // 10
    printf("%lld\n", (long long)(D));            // 11
    printf("%lld\n", (long long)(ALPHA));        // 1
    printf("%lld\n", (long long)(BETA));         // 2
    printf("%lld\n", (long long)(GAMMA));        // 10
    printf("%lld\n", (long long)(classify(RED)));    // 100
    printf("%lld\n", (long long)(classify(GREEN)));  // 200
    printf("%lld\n", (long long)(classify(BLUE)));   // 300

    // Enumerators are usable in arbitrary integer contexts.
    int x = D + 5;
    printf("%lld\n", (long long)(x));            // 16
    return 0;
}
