// Block-local typedef inside a function body. Real C allows typedef
// declarations anywhere a declaration is allowed, including statement
// scope. Used by corec's test_base.c and similar.

int main() {
    typedef struct { int x; int y; } S;
    S s;
    s.x = 10;
    s.y = 32;
    _tinyc_print(s.x + s.y);  // 42

    // Local typedef of a primitive aliased to size_t-style name.
    typedef int MyInt;
    MyInt n = 7;
    _tinyc_print(n);          // 7
    return 0;
}
