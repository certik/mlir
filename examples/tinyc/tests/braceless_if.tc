extern int printf(const char *fmt, ...);
// `if (cond) stmt;` and `else stmt;` without braces are accepted and
// behave just like the equivalent braced versions.
int main() {
    int i;
    int s;
    s = 0;
    for (i = 0; i < 5; i = i + 1) if (i != 2) s = s + i;
    printf("%lld\n", (long long)(s));  // 0+1+3+4 = 8

    int x;
    x = 7;
    if (x > 0) printf("%lld\n", (long long)(x)); else printf("%lld\n", (long long)(0 - x));  // 7

    if (x < 0) printf("%lld\n", (long long)(0 - x));
    else if (x == 0) printf("%lld\n", (long long)(99));
    else printf("%lld\n", (long long)(x));  // 7

    // Nested braceless single-statement bodies.
    if (x > 0)
        if (x < 10) printf("%lld\n", (long long)(x));  // 7
    return 0;
}
