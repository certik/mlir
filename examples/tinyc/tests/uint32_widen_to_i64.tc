extern int printf(const char *fmt, ...);
// MRE: tinyc sign-extends `(int64_t)<uint32_t>` casts. Any uint32_t
// value with bit 31 set widens to 0xffffffff80000000 in i64 instead of
// 0x0000000080000000, so when it's later printed or used in a 64-bit
// hash mixing step the result is wrong.
//
// Two compiler paths are bugged:
//   1. The EX_CAST handler emits `arith.extsi` unconditionally when
//      widening i32 -> i64. It must use `arith.extui` for `unsigned`
//      sources.
//   2. The EX_CALL handler does not copy the function-signature
//      return type's `int_unsigned` flag into the result EVal, so
//      `(int64_t)f()` where `f` returns `uint32_t` widens via extsi
//      even after path 1 is fixed.
//
// This breaks SHA-256 inside `mlir_wasm_to_macho.c` when run as
// `wasmtime tinyc_stage2.wasm -- --emit=macho ...`: the 8-byte
// big-endian bit-length trailer that closes every SHA-256 block
// holds `bitlen` (uint64_t) but is built by accumulating 32-bit
// quantities — and any uint32_t with bit 31 set becomes a huge
// negative value, breaking every page hash.
//
// Expected output: three lines, each "2147483648" (i.e. 0x80000000).
// With the bug each line prints "-2147483648".

typedef unsigned int  uint32_t;
typedef long long     int64_t;

static uint32_t mask_high_bit(uint32_t x) {
    return x | 0x80000000u;
}

int main() {
    uint32_t a = 0x80000000u;
    // (int64_t)<unsigned variable> — direct widening of an l-value.
    printf("%lld\n", (long long)((int64_t)a));
    // (int64_t)<unsigned call result> — widening of an EX_CALL value.
    printf("%lld\n", (long long)((int64_t)mask_high_bit(0)));
    // (int64_t)<unsigned shift result> — widening of an arith result
    // whose `is_unsigned` came from the LHS shift operand.
    uint32_t v = ((uint32_t)1) << 31;
    printf("%lld\n", (long long)((int64_t)v));
    return 0;
}
