extern int printf(const char *fmt, ...);
// Struct with an array of char* fields, populated from string literals.

struct StrTable {
    char* names[3];
};

int main() {
    struct StrTable t;
    t.names[0] = "alpha";
    t.names[1] = "beta";
    t.names[2] = "gamma";

    int i = 0;
    while (i < 3) {
        printf("%s\n", t.names[i]);
        i = i + 1;
    }

    // Reassign one slot.
    t.names[1] = "BETA!";
    printf("%s\n", t.names[1]);
    return 0;
}
