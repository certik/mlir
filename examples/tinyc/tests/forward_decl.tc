int is_even(int n);
int is_odd(int n);

int is_even(int n) {
    if (n == 0) { return 1; }
    return is_odd(n - 1);
}

int is_odd(int n) {
    if (n == 0) { return 0; }
    return is_even(n - 1);
}

int add3(int, int, int);

int add3(int a, int b, int c) {
    return a + b + c;
}

int main() {
    print(is_even(10));    // 1
    print(is_odd(7));      // 1
    print(is_even(3));     // 0
    print(add3(1, 2, 3));  // 6
    return 0;
}
