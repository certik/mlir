extern int printf(const char *fmt, ...);
// Struct with a 1D array-of-int field. Exercises field-array reads,
// writes, &field[i] address-of, and pointer arithmetic on that address.

struct Buf {
    int n;
    int data[8];
};

int sum_via_ptr(int* p, int n) {
    int s = 0;
    int i = 0;
    while (i < n) {
        s = s + *p;
        p = p + 1;
        i = i + 1;
    }
    return s;
}

int main() {
    struct Buf b;
    b.n = 8;
    int i = 0;
    while (i < b.n) {
        b.data[i] = i * i;
        i = i + 1;
    }
    printf("%lld\n", (long long)(b.n));          // 8
    printf("%lld\n", (long long)(b.data[0]));    // 0
    printf("%lld\n", (long long)(b.data[3]));    // 9
    printf("%lld\n", (long long)(b.data[7]));    // 49

    // &b.data[i] yields int*; pointer arithmetic must work.
    int* p = &b.data[0];
    printf("%lld\n", (long long)(*p));           // 0
    p = p + 5;
    printf("%lld\n", (long long)(*p));           // 25
    printf("%lld\n", (long long)(sum_via_ptr(&b.data[0], b.n)));  // 0+1+4+9+16+25+36+49 = 140
    return 0;
}
