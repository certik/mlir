extern int printf(const char *fmt, ...);
struct Point {
    int x;
    int y;
};

struct Stat {
    int n;
    float mean;
};

int dot(struct Point a, struct Point b) {
    return a.x * b.x + a.y * b.y;
}

struct Point add(struct Point a, struct Point b) {
    struct Point r;
    r.x = a.x + b.x;
    r.y = a.y + b.y;
    return r;
}

struct Point scale(struct Point p, int k) {
    struct Point r;
    r.x = p.x * k;
    r.y = p.y * k;
    return r;
}

struct Stat make_stat(int n, float m) {
    struct Stat s;
    s.n = n;
    s.mean = m;
    return s;
}

int main() {
    struct Point a;
    a.x = 1;
    a.y = 2;
    struct Point b;
    b.x = 3;
    b.y = 4;

    printf("%lld\n", (long long)(dot(a, b)));            // 1*3 + 2*4 = 11

    struct Point c;
    c = add(a, b);
    printf("%lld\n", (long long)(c.x));                   // 4
    printf("%lld\n", (long long)(c.y));                   // 6

    struct Point d;
    d = scale(c, 5);
    printf("%lld\n", (long long)(d.x));                   // 20
    printf("%lld\n", (long long)(d.y));                   // 30

    // Struct-returning call result, then pass that struct as an arg
    struct Point e2;
    e2 = scale_helper_ok();
    struct Point e;
    e = add(e2, b);
    printf("%lld\n", (long long)(e.x));                   // 10 + 3 = 13
    printf("%lld\n", (long long)(e.y));                   // 20 + 4 = 24

    // Mixed scalar + struct params, struct return with float field
    struct Stat s;
    s = make_stat(7, 3.5);
    printf("%lld\n", (long long)(s.n));                   // 7
    printf("%g\n", (double)(s.mean));                // 3.5
    return 0;
}

struct Point scale_helper_ok() {
    struct Point p;
    p.x = 10;
    p.y = 20;
    return p;
}
