extern int printf(const char *fmt, ...);
// `(void)` as the only-parameter form, plus a normal void-returning
// function that takes one parameter.
int answer(void) {
    return 42;
}

void announce(int x) {
    printf("%lld\n", (long long)(x));
}

int main() {
    printf("%lld\n", (long long)(answer()));   // 42
    announce(7);       // 7
    announce(answer());// 42
    return 0;
}
