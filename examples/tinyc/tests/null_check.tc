extern int printf(const char *fmt, ...);
// Exercise pointer comparisons against null.

struct Box {
    int value;
    struct Box* link;
};

int has_link(struct Box* p) {
    if (p->link == null) {
        return 0;
    }
    return 1;
}

int has_link_ne(struct Box* p) {
    if (p->link != null) {
        return 1;
    }
    return 0;
}

int main() {
    struct Box* a;
    struct Box* b;
    a = (struct Box*)malloc(sizeof(struct Box));
    b = (struct Box*)malloc(sizeof(struct Box));
    a->value = 1; a->link = b;
    b->value = 2; b->link = null;

    printf("%lld\n", (long long)(has_link(a)));     // 1
    printf("%lld\n", (long long)(has_link(b)));     // 0
    printf("%lld\n", (long long)(has_link_ne(a)));  // 1
    printf("%lld\n", (long long)(has_link_ne(b)));  // 0

    // Reassign a's link to null and re-check.
    a->link = null;
    printf("%lld\n", (long long)(has_link(a)));     // 0

    // Compare two pointers directly.
    struct Box* c;
    c = a;
    if (a == c) { printf("%lld\n", (long long)(42)); }       // 42
    if (a != b) { printf("%lld\n", (long long)(99)); }       // 99

    free(a); free(b);
    return 0;
}
