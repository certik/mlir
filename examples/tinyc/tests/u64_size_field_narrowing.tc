// Stage-2 selfhost MRE attempt: mimic the `attr_s` pattern where a
// struct field of type uint64_t is passed to a function expecting
// size_t. On wasm32 size_t is 4 bytes and uint64_t is 8 bytes; the
// caller must narrow at the call site or the receiver reads garbage.
//
// The original failing site:
//
//   static MLIR_AttributeHandle attr_s(..., const char *v, size_t vlen) {
//       string sv = { (char *)v, vlen };
//       return MLIR_CreateAttributeString(ctx, ..., sv);
//   }
//
//   attr_s(ctx, "target", o->call_target.str, o->call_target.size);
//                                              ^^^ uint64_t here
//
// Reproduce: a function takes (char *p, size_t n) and stuffs them
// into a `string` (which has a uint64_t size field). Then we
// read back .size and .str.

int printf(char *fmt, ...);

typedef struct { char *str; unsigned long long size; } str_t;

struct holder {
    char *str;
    unsigned long long size;
};

str_t build(char *p, unsigned long n) {
    str_t sv;
    sv.str = p;
    sv.size = (unsigned long long)n;
    return sv;
}

int main() {
    struct holder h;
    h.str = "abcdef";
    h.size = 6;
    str_t s = build(h.str, h.size);
    printf("size=%llu str0=%c\n", s.size, s.str[0]);
    return 0;
}
