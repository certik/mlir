extern int printf(const char *fmt, ...);
// Regression test: aggregate initializers must allow nested `{...}`
// for struct-typed fields.
//
// Before this fix, tinyc's parser called parse_expr on each element of
// an aggregate, so `{ 7, { 3, 4 } }` was rejected with
//   "expected expression / expected '}' in initializer".
// The fix recurses into parse_aggregate_init when an element starts
// with `{`, and the emitter propagates the surrounding field's type
// down to the inner EX_COMPOUND.
//
// Mirrors the shape of `static PPTok eof = { PP_END, {NULL,0}, ... };`
// from examples/tinyc/preprocess.c, but uses block-scope locals so the
// test does not also depend on function-scope `static` storage.

typedef struct { int a; int b; } Inner;
typedef struct { int kind; Inner text; } Outer;

int main(void) {
    Outer eof = { 7, { 3, 4 } };
    printf("%lld\n", (long long)(eof.kind));
    printf("%lld\n", (long long)(eof.text.a));
    printf("%lld\n", (long long)(eof.text.b));

    // Multiple nested struct fields + a trailing scalar field.
    typedef struct {
        int code;
        Inner ll;
        Inner ur;
        int tail;
    } Multi;
    Multi m = { 11, { 1, 2 }, { 30, 40 }, 99 };
    printf("%lld\n", (long long)(m.code));
    printf("%lld\n", (long long)(m.ll.a));
    printf("%lld\n", (long long)(m.ll.b));
    printf("%lld\n", (long long)(m.ur.a));
    printf("%lld\n", (long long)(m.ur.b));
    printf("%lld\n", (long long)(m.tail));
    return 0;
}
