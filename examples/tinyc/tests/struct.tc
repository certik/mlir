extern int printf(const char *fmt, ...);
struct Point {
    int x;
    int y;
};

struct Stats {
    int count;
    float sum;
};

int main() {
    struct Point p;
    p.x = 3;
    p.y = 4;
    printf("%lld\n", (long long)(p.x));
    printf("%lld\n", (long long)(p.y));
    printf("%lld\n", (long long)(p.x * p.x + p.y * p.y));

    struct Stats s;
    s.count = 0;
    s.sum = 0.0;
    int i = 0;
    while (i < 5) {
        s.count = s.count + 1;
        s.sum = s.sum + 1.5;
        i = i + 1;
    }
    printf("%lld\n", (long long)(s.count));
    printf("%g\n", (double)(s.sum));
    return 0;
}
