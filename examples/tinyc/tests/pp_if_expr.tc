extern int printf(const char *fmt, ...);
// Constant expression evaluation in #if.

#define X 7

int main() {
#if (3 + 4) * 2 == 14
    printf("%lld\n", (long long)(1));            // 1
#endif

#if X * X - 1 == 48
    printf("%lld\n", (long long)(2));            // 2
#endif

#if (1 << 4) | 2 == 18
    printf("%lld\n", (long long)(3));            // 3
#endif

#if 1 ? 4 : 99
    printf("%lld\n", (long long)(4));            // 4
#endif

#if 0 ? 99 : 5
    printf("%lld\n", (long long)(5));            // 5
#endif

#if (10 % 3) == 1 && (10 / 3) == 3
    printf("%lld\n", (long long)(6));            // 6
#endif

#if !(0)
    printf("%lld\n", (long long)(7));            // 7
#endif

#if ~0 == -1
    printf("%lld\n", (long long)(8));            // 8
#endif

#if defined(X) + defined(Y) == 1
    printf("%lld\n", (long long)(9));            // 9
#endif

    return 0;
}
