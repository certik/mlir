extern int printf(const char *fmt, ...);
// Early `return` from inside if/while is now legal under cf-style lowering.
int find_first_pos(int n) {
    int i = 0;
    while (i < n) {
        if (i == 3) {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

int main() {
    printf("%lld\n", (long long)(find_first_pos(10)));   // 3
    printf("%lld\n", (long long)(find_first_pos(2)));    // -1
    return 0;
}
