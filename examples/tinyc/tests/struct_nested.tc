extern int printf(const char *fmt, ...);
struct Inner {
    int x;
    int y;
};

struct Outer {
    struct Inner i;
    int z;
};

int sum(struct Outer o) {
    return o.i.x + o.i.y + o.z;
}

int sum_via_ptr(struct Outer* o) {
    return o->i.x + o->i.y + o->z;
}

struct Outer make() {
    struct Outer o;
    o.i.x = 1;
    o.i.y = 2;
    o.z = 3;
    return o;
}

int main() {
    struct Outer o;
    o.i.x = 10;
    o.i.y = 20;
    o.z = 30;
    printf("%lld\n", (long long)(o.i.x));
    printf("%lld\n", (long long)(o.i.y));
    printf("%lld\n", (long long)(o.z));
    printf("%lld\n", (long long)(sum(o)));
    printf("%lld\n", (long long)(sum_via_ptr(&o)));

    struct Outer m;
    m = make();
    printf("%lld\n", (long long)(m.i.x));
    printf("%lld\n", (long long)(m.i.y));
    printf("%lld\n", (long long)(m.z));
    printf("%lld\n", (long long)(sum(m)));
    return 0;
}
