extern int printf(const char *fmt, ...);
// Regression: tinyc must accept the full C escape set in both string
// and character literals. Previously \v \f \a \b \? were rejected.
int main() {
    char *s;
    s = "\v\f\a\b\?";
    printf("%lld\n", (long long)(s[0]));
    printf("%lld\n", (long long)(s[1]));
    printf("%lld\n", (long long)(s[2]));
    printf("%lld\n", (long long)(s[3]));
    printf("%lld\n", (long long)(s[4]));
    printf("%lld\n", (long long)('\v'));
    printf("%lld\n", (long long)('\f'));
    printf("%lld\n", (long long)('\a'));
    printf("%lld\n", (long long)('\b'));
    printf("%lld\n", (long long)('\?'));
    return 0;
}
