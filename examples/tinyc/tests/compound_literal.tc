extern int printf(const char *fmt, ...);
struct Point {
    int x;
    int y;
};

int add_pt(struct Point *p) {
    return p->x + p->y;
}

int main() {
    int a;
    long long b;
    struct Point p = (struct Point){3, 4};
    a = (int){42};
    b = (long long){7};
    printf("%lld\n", (long long)(a));
    printf("%lld\n", (long long)(b));
    printf("%lld\n", (long long)(p.x));
    printf("%lld\n", (long long)(p.y));
    printf("%lld\n", (long long)(add_pt(&p)));
    return 0;
}
