extern int printf(const char *fmt, ...);
// Aggregate initializer for struct locals: positional and designated.

typedef struct Pt {
    int x;
    int y;
    int z;
} Pt;

int main() {
    Pt a = {1, 2, 3};
    Pt b = {.x = 10, .y = 20, .z = 30};
    Pt c = {.z = 700, .x = 100, .y = 400};
    printf("%lld\n", (long long)(a.x)); printf("%lld\n", (long long)(a.y)); printf("%lld\n", (long long)(a.z));
    printf("%lld\n", (long long)(b.x)); printf("%lld\n", (long long)(b.y)); printf("%lld\n", (long long)(b.z));
    printf("%lld\n", (long long)(c.x)); printf("%lld\n", (long long)(c.y)); printf("%lld\n", (long long)(c.z));
    return 0;
}
