extern int printf(const char *fmt, ...);
// Exercise sizeof on basic and composite types.

struct Pair {
    int a;
    int b;
};

struct WithPtr {
    int v;
    struct Pair* p;
};

int main() {
    printf("%lld\n", (long long)(sizeof(int)));               // 4
    printf("%lld\n", (long long)(sizeof(float)));             // 4
    printf("%lld\n", (long long)(sizeof(struct Pair)));       // 8
    printf("%lld\n", (long long)(sizeof(struct WithPtr)));    // 16: int(4) + pad(4) + ptr(8)
    return 0;
}
