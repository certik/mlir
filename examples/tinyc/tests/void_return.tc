extern int printf(const char *fmt, ...);
// `void` return type with a bare `return;` early exit.
void greet(int n) {
    if (n < 0) {
        printf("%lld\n", (long long)(-1));
        return;
    }
    printf("%lld\n", (long long)(n));
}

int main() {
    greet(7);     // 7
    greet(-3);    // -1
    greet(42);    // 42
    return 0;
}
