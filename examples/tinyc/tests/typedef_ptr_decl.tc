extern int printf(const char *fmt, ...);
// `Td *p;` declares a pointer-to-typedef variable; the parser must
// recognize this even though `*` (not an IDENT) immediately follows the
// typedef name.
typedef struct point_s { int x; int y; } Point;

int main() {
    Point a;
    a.x = 3;
    a.y = 4;

    Point *p;
    p = &a;
    printf("%lld\n", (long long)(p->x));     // 3
    printf("%lld\n", (long long)(p->y));     // 4

    Point *q = &a;
    printf("%lld\n", (long long)(q->x + q->y));  // 7
    return 0;
}
