extern int printf(const char *fmt, ...);
int sum7(int a,int b,int c,int d,int e,int f,int g){ return a+b+c+d+e+f+g; }
int sum9(int a,int b,int c,int d,int e,int f,int g,int h,int i){ return a+b+c+d+e+f+g+h+i; }
int main(){
    printf("%lld\n", (long long)(sum7(1,2,3,4,5,6,7)));        // 28
    printf("%lld\n", (long long)(sum9(1,2,3,4,5,6,7,8,9)));    // 45
    printf("%lld\n", (long long)(sum7(10,20,30,40,50,60,70))); // 280
    return 0;
}
