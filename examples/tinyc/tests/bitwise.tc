extern int printf(const char *fmt, ...);
int main() {
    printf("%lld\n", (long long)(5 & 3));
    printf("%lld\n", (long long)(5 | 2));
    printf("%lld\n", (long long)(5 ^ 3));
    printf("%lld\n", (long long)(~0));
    printf("%lld\n", (long long)(1 << 3));
    printf("%lld\n", (long long)(16 >> 2));
    int x = 12;
    x &= 10;
    printf("%lld\n", (long long)(x));
    x = 1;
    x |= 4;
    printf("%lld\n", (long long)(x));
    x ^= 7;
    printf("%lld\n", (long long)(x));
    x = 1;
    x <<= 4;
    printf("%lld\n", (long long)(x));
    x >>= 2;
    printf("%lld\n", (long long)(x));
    return 0;
}
