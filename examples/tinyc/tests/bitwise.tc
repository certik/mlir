int main() {
    print(5 & 3);
    print(5 | 2);
    print(5 ^ 3);
    print(~0);
    print(1 << 3);
    print(16 >> 2);
    int x = 12;
    x &= 10;
    print(x);
    x = 1;
    x |= 4;
    print(x);
    x ^= 7;
    print(x);
    x = 1;
    x <<= 4;
    print(x);
    x >>= 2;
    print(x);
    return 0;
}
