extern int printf(const char *fmt, ...);
struct S { int a; int b; };

struct S make(int x) {
    struct S s;
    s.a = x;
    s.b = x * 10;
    return s;
}

typedef struct S (*Fn)(int);

int main() {
    Fn f = make;
    struct S r = f(7);
    printf("%lld\n", (long long)(r.a));
    printf("%lld\n", (long long)(r.b));
    printf("%lld\n", (long long)(r.a + r.b));
    return 0;
}
