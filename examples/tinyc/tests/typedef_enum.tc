extern int printf(const char *fmt, ...);
// `typedef enum { ... } Name;` registers Name as a typedef for int and
// brings the enumerators into scope as int constants.
typedef enum {
    COLOR_RED,    // 0
    COLOR_GREEN,  // 1
    COLOR_BLUE    // 2
} Color;

int classify(Color c) {
    if (c == COLOR_RED) return 100;
    if (c == COLOR_GREEN) return 200;
    return 300;
}

int main() {
    Color c;
    c = COLOR_GREEN;
    printf("%lld\n", (long long)(c));            // 1
    printf("%lld\n", (long long)(classify(c)));  // 200
    printf("%lld\n", (long long)(COLOR_BLUE));   // 2
    return 0;
}
