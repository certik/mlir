extern int printf(const char *fmt, ...);
int main() {
    int i = 1, j = 2, k = 3;
    int a, b = 5, c;
    a = 10; c = 20;
    int *p = &i, *q = &j;
    int64_t x = 100, y = 200;
    printf("%lld\n", (long long)((int64_t)i));
    printf("%lld\n", (long long)((int64_t)j));
    printf("%lld\n", (long long)((int64_t)k));
    printf("%lld\n", (long long)((int64_t)a));
    printf("%lld\n", (long long)((int64_t)b));
    printf("%lld\n", (long long)((int64_t)c));
    printf("%lld\n", (long long)((int64_t)*p));
    printf("%lld\n", (long long)((int64_t)*q));
    printf("%lld\n", (long long)(x));
    printf("%lld\n", (long long)(y));
    return 0;
}
