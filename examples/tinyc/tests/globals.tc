extern int printf(const char *fmt, ...);
int counter = 1;
int total;
float pi = 3.0;
char *greeting = "Hi";

int bump() {
    counter = counter + 1;
    return counter;
}

int main() {
    printf("%s\n", greeting);
    printf("%lld\n", (long long)(counter));
    bump();
    bump();
    printf("%lld\n", (long long)(counter));
    total = counter * 10;
    printf("%lld\n", (long long)(total));
    printf("%g\n", (double)(pi));
    return 0;
}
