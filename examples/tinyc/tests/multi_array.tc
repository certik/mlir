int main() {
    int m[3][4];
    int i;
    int j;
    for (i = 0; i < 3; i = i + 1) {
        for (j = 0; j < 4; j = j + 1) {
            m[i][j] = i * 10 + j;
        }
    }
    print(m[0][0]);    // 0
    print(m[1][2]);    // 12
    print(m[2][3]);    // 23

    int sum = 0;
    for (i = 0; i < 3; i = i + 1) {
        for (j = 0; j < 4; j = j + 1) {
            sum = sum + m[i][j];
        }
    }
    print(sum);        // 0+1+2+3 + 10+11+12+13 + 20+21+22+23 = 138
    return 0;
}
