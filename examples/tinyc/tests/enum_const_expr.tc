extern int printf(const char *fmt, ...);
// Regression test: enum initializers accept full constant expressions.
// Previously tinyc only accepted a single int literal or a previously-
// declared enumerator (optionally with a unary minus). Standard C allows
// any integer constant expression, including arithmetic, bitwise ops,
// shifts, comparisons, and ternaries built from integer literals and
// already-declared enumerators.
//
// Used in mlir_wasm_link.c (~line 1330):
//     enum {
//         PAGE_SIZE     = 65536u,
//         STACK_SIZE    = 64u * 1024u,
//         INITIAL_PAGES = 2u,
//         GLOBAL_BASE_OFFSET = 1024u,
//     };

enum {
    PAGE_SIZE          = 65536u,
    STACK_SIZE         = 64u * 1024u,
    INITIAL_PAGES      = 2u,
    GLOBAL_BASE_OFFSET = 1024u,
};

enum {
    A = 1,
    B = A + 2,
    C = A * 10 + B,
    D = (1 << 8) | 0xff,
    E = ~0,
    F = A == 1 ? 100 : 200,
    G = -A,
    H = A < B ? B - A : 0,
    I = (5 + 3) * 2 - 1,
};

int main(void) {
    printf("%lld\n", (long long)(PAGE_SIZE));            // 65536
    printf("%lld\n", (long long)(STACK_SIZE));           // 65536
    printf("%lld\n", (long long)(INITIAL_PAGES));        // 2
    printf("%lld\n", (long long)(GLOBAL_BASE_OFFSET));   // 1024

    printf("%lld\n", (long long)(A));  // 1
    printf("%lld\n", (long long)(B));  // 3
    printf("%lld\n", (long long)(C));  // 13
    printf("%lld\n", (long long)(D));  // 511
    printf("%lld\n", (long long)(E));  // -1
    printf("%lld\n", (long long)(F));  // 100
    printf("%lld\n", (long long)(G));  // -1
    printf("%lld\n", (long long)(H));  // 2
    printf("%lld\n", (long long)(I));  // 15

    return 0;
}
