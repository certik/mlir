extern int printf(const char *fmt, ...);
typedef int (*BinOp)(int, int);

int add(int a, int b) {
    return a + b;
}

int sub(int a, int b) {
    return a - b;
}

int run(BinOp op, int x, int y) {
    return op(x, y);
}

int main() {
    BinOp f;
    f = &add;
    printf("%lld\n", (long long)(f(20, 22)));
    printf("%lld\n", (long long)(run(sub, 50, 8)));
    return 0;
}
