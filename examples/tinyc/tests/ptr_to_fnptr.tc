extern int printf(const char *fmt, ...);
int add(int a, int b) {
    return a + b;
}

int sub(int a, int b) {
    return a - b;
}

int main() {
    int (*op)(int, int);
    int (**pop)(int, int);
    op = &add;
    pop = &op;
    printf("%lld\n", (long long)((*pop)(2, 3)));
    op = &sub;
    printf("%lld\n", (long long)((*pop)(10, 3)));
    return 0;
}
