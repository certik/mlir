extern int printf(const char *fmt, ...);
int add(int a, int b) {
    return a + b;
}

int mul(int a, int b) {
    return a * b;
}

int apply(int (*op)(int, int), int x, int y) {
    return op(x, y);
}

int main() {
    printf("%lld\n", (long long)(apply(&add, 5, 7)));
    printf("%lld\n", (long long)(apply(mul, 6, 7)));
    return 0;
}
