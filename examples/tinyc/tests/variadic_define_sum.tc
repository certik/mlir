extern int printf(const char *fmt, ...);
// Define a variadic function and consume its varargs via the standard
// va_list / va_start / va_arg / va_end machinery.
int sum(int n, ...) {
    va_list ap;
    va_start(ap, n);
    int total;
    total = 0;
    int i;
    i = 0;
    while (i < n) {
        total = total + va_arg(ap, int);
        i = i + 1;
    }
    va_end(ap);
    return total;
}

int main() {
    printf("%lld\n", (long long)(sum(3, 10, 20, 30)));   // 60
    printf("%lld\n", (long long)(sum(5, 1, 2, 3, 4, 5))); // 15
    printf("%lld\n", (long long)(sum(1, 99)));            // 99
    return 0;
}
