// Anonymous struct typedef and tag-only struct typedef both register
// a struct that can be used by the typedef name.
typedef struct {
    int x;
    int y;
} Point;

typedef struct Box {
    int w;
    int h;
} Box;

int main() {
    Point p;
    p.x = 3;
    p.y = 4;
    print(p.x + p.y);  // 7

    Box b;
    b.w = 5;
    b.h = 6;
    print(b.w * b.h);  // 30
    return 0;
}
