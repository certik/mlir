extern int printf(const char *fmt, ...);
int main() {
    printf("%lld\n", (long long)(0755));
    printf("%lld\n", (long long)(010));
    printf("%lld\n", (long long)(0));
    printf("%lld\n", (long long)(0777));
    printf("%lld\n", (long long)(0x1F));
    printf("%lld\n", (long long)(100));
    printf("%lld\n", (long long)(01000));
    return 0;
}
