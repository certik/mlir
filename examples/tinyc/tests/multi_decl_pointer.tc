extern int printf(const char *fmt, ...);
// Regression test: multi-declarator local declarations where each
// declarator has its own pointer suffix:
//
//     T *a, *b;
//
// Previously tinyc accepted `T *a, b;` (re-using the base typedef
// type) but choked on the second `*` with
//     "expected identifier" / "expected ';'"
// because the comma-loop did not consume per-declarator pointer
// suffixes.
//
// Used in examples/tinyc/emit.c at line 1126:
//     Expr *idx_a = NULL, *idx_b = NULL;

typedef struct Expr_s { int v; } Expr;

int main(void) {
    Expr a;
    a.v = 11;
    Expr b;
    b.v = 22;

    Expr *p = &a, *q = &b;
    printf("%lld\n", (long long)(p->v));
    printf("%lld\n", (long long)(q->v));

    // Mixed: pointer + non-pointer (currently both end up pointers,
    // matching tinyc's existing simplification).
    Expr *r = &a, *s = &b;
    if (r == p) printf("%lld\n", (long long)(100));
    if (s == q) printf("%lld\n", (long long)(200));

    // int* with multiple decls + inits.
    int x = 7, y = 8;
    int *px = &x, *py = &y;
    printf("%lld\n", (long long)(*px + *py));
    return 0;
}
