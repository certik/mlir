extern int printf(const char *fmt, ...);
int main() {
    int a = 0x40;
    int b = (0x40 | 0x4 | 0x20);
    int c = 0xFF;
    int64_t d = 0xabcdL;
    printf("%lld\n", (long long)((int64_t)a));
    printf("%lld\n", (long long)((int64_t)b));
    printf("%lld\n", (long long)((int64_t)c));
    printf("%lld\n", (long long)(d));
    return 0;
}
