extern int printf(const char *fmt, ...);
// Benchmark for comparing backends.
// - fib(N) exercises recursion / call frames / branches.
// - The big loop exercises integer arithmetic in a tight loop.
// Both should be CPU-bound and run for ~1-10s depending on the backend.

int fib(int n) {
    if (n < 2) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

int main() {
    int f = fib(34);
    printf("%lld\n", (long long)(f));

    int n = 200000000;
    int s = 0;
    int i = 0;
    while (i < n) {
        s = s + i * 3 + 1;
        i = i + 1;
    }
    printf("%lld\n", (long long)(s));

    return 0;
}
