int classify(int n) {
    int r = -1;
    switch (n) {
        case 0:
            r = 100;
            break;
        case 1:
        case 2:
            r = 200;
            break;
        case 3:
            r = 300;
            // fallthrough
        case 4:
            r = r + 1;
            break;
        default:
            r = 999;
            break;
    }
    return r;
}

int main() {
    print(classify(0));   // 100
    print(classify(1));   // 200
    print(classify(2));   // 200
    print(classify(3));   // 301
    print(classify(4));   // 0 (r starts -1, +1 = 0)
    print(classify(7));   // 999

    int i;
    int sum = 0;
    for (i = 0; i < 5; i = i + 1) {
        switch (i) {
            case 0:
            case 1:
                sum = sum + 1;
                break;
            case 2:
                continue;
            default:
                sum = sum + 10;
        }
    }
    print(sum);           // i=0:+1, i=1:+1, i=2:continue, i=3:+10, i=4:+10 = 22
    return 0;
}
